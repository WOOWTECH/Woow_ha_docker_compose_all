# ============================================================
# Home Assistant + PostgreSQL  —  Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=homeassistant
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=homeassistant
POSTGRES_PORT=5432

# ---------- Home Assistant ----------
HA_VERSION=stable
HA_PORT=8123

# ---------- General ----------
TZ=Asia/Taipei
